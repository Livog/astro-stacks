---
import Stack from "astro-stacks/stack.astro";
import IconSprite from "astro-icon-sprite/icon-sprite.astro";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Astro Stacks" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <Stack name="head" />
  </head>
  <body class="min-h-screen bg-zinc-950 text-zinc-100 font-sans antialiased">
    <div class="mx-auto max-w-3xl px-6 py-12">
      <slot />
    </div>

    <IconSprite />
    <Stack name="beforeBodyEnd" />
  </body>
</html>
