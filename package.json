{
  "name": "astro-stacks",
  "version": "1.0.0",
  "type": "module",
  "description": "Laravel Blade-style @stack/@push system for Astro SSR",
  "keywords": [
    "astro",
    "astro-integration",
    "ssr",
    "stacks",
    "push",
    "middleware"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Livog/astro-stacks.git"
  },
  "author": "Livog",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./stack.astro": "./dist/stack.astro",
    "./middleware": "./dist/middleware.ts"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && cp src/*.astro dist/ && cp src/middleware.ts dist/",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "astro": ">=4.0.0"
  },
  "devDependencies": {
    "astro": "^6.0.0-beta.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "workspaces": [
    "demo"
  ]
}
